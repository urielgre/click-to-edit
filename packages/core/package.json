{
  "name": "click-to-edit",
  "version": "0.1.0-alpha.0",
  "description": "Click any text in your Next.js app, edit it inline, save to source. Dev-mode click-to-edit overlay for Next.js (App Router).",
  "keywords": [
    "nextjs",
    "react",
    "click-to-edit",
    "inline-edit",
    "wysiwyg",
    "visual-editor",
    "developer-tools",
    "claude-code",
    "vibe-coding"
  ],
  "license": "MIT",
  "author": "Uriel (@urielgre)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/urielgre/click-to-edit.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/urielgre/click-to-edit#readme",
  "bugs": {
    "url": "https://github.com/urielgre/click-to-edit/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "require": "./dist/loader.cjs"
    }
  },
  "bin": {
    "click-to-edit": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
