{
  "name": "click-to-edit-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for click-to-edit: inline click-to-edit overlay for Next.js apps.",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "test": "pnpm -r --filter \"./packages/*\" test",
    "dev:example": "pnpm --filter example dev",
    "dev:core": "pnpm --filter click-to-edit dev"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=18"
  }
}
